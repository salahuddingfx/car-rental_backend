# Block PHP execution in uploads directory
php_flag engine off

<FilesMatch "\.php[0-9]*$">
    Deny from all
</FilesMatch>

<FilesMatch "\.phtml$">
    Deny from all
</FilesMatch>

<FilesMatch "\.pht$">
    Deny from all
</FilesMatch>

<FilesMatch "\.phps$">
    Deny from all
</FilesMatch>

# Prevent directory listing
Options -Indexes
